{
	"name": "halka",
	"version": "0.1.3",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/hasinoorit/halka.git"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && npm run prepack",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./plugins/table": {
			"types": "./dist/plugins/table.d.ts",
			"import": "./dist/plugins/table.js",
			"default": "./dist/plugins/table.js"
		},
		"./plugins/footnote": {
			"types": "./dist/plugins/footnote.d.ts",
			"import": "./dist/plugins/footnote.js",
			"default": "./dist/plugins/footnote.js"
		},
		"./plugins/history": {
			"types": "./dist/plugins/history.d.ts",
			"import": "./dist/plugins/history.js",
			"default": "./dist/plugins/history.js"
		},
		"./plugins/image": {
			"types": "./dist/plugins/image.d.ts",
			"import": "./dist/plugins/image.js",
			"default": "./dist/plugins/image.js"
		},
		"./plugins/link": {
			"types": "./dist/plugins/link.d.ts",
			"import": "./dist/plugins/link.js",
			"default": "./dist/plugins/link.js"
		},
		"./plugins/list": {
			"types": "./dist/plugins/list.d.ts",
			"import": "./dist/plugins/list.js",
			"default": "./dist/plugins/list.js"
		},
		"./plugins/markdown-shortcuts": {
			"types": "./dist/plugins/markdown-shortcuts.d.ts",
			"import": "./dist/plugins/markdown-shortcuts.js",
			"default": "./dist/plugins/markdown-shortcuts.js"
		},
		"./plugins/paste": {
			"types": "./dist/plugins/paste.d.ts",
			"import": "./dist/plugins/paste.js",
			"default": "./dist/plugins/paste.js"
		},
		"./plugins/placeholder": {
			"types": "./dist/plugins/placeholder.d.ts",
			"import": "./dist/plugins/placeholder.js",
			"default": "./dist/plugins/placeholder.js"
		},
		"./plugins/find-replace": {
			"types": "./dist/plugins/find-replace.d.ts",
			"import": "./dist/plugins/find-replace.js",
			"default": "./dist/plugins/find-replace.js"
		}
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@eslint/compat": "^1.4.0",
		"@eslint/js": "^9.39.1",
		"@playwright/test": "^1.57.0",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.49.1",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/forms": "^0.5.10",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.17",
		"@types/node": "^22",
		"@vitest/browser-playwright": "^4.0.15",
		"eslint": "^9.39.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.13.1",
		"globals": "^16.5.0",
		"jsdom": "^27.4.0",
		"playwright": "^1.57.0",
		"prettier": "^3.7.4",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"publint": "^0.3.15",
		"svelte": "^5.45.6",
		"svelte-check": "^4.3.4",
		"tailwind-merge": "^3.4.0",
		"tailwindcss": "^4.1.17",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.48.1",
		"vite": "^7.2.6",
		"vitest": "^4.0.15",
		"vitest-browser-svelte": "^2.0.1"
	},
	"keywords": [
		"svelte"
	]
}
