{
	"extends": "./.svelte-kit/tsconfig.json",
	"compilerOptions": {
		"rewriteRelativeImportExtensions": true,
		"allowJs": true,
		"checkJs": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"sourceMap": true,
		"strict": true,
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"allowArbitraryExtensions": true
	},
	"exclude": [
		"node_modules",
		".svelte-kit",
		"**/*.spec.ts",
		"**/*.test.ts",
		"**/*.spec.js",
		"**/*.test.js"
	]
}